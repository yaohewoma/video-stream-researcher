stateDiagram-v2
    [*] --> Ready: 应用启动
    
    state "⬇️ 下载状态机" as DownloadState {
        Ready --> Parsing: 用户点击下载
        
        Parsing --> Checking: 解析成功
        Parsing --> Failed: 解析失败
        
        Checking --> Downloading: 文件不存在
        Checking --> Confirming: 文件存在(未确认)
        Checking --> Skipped: 文件存在(已确认)
        
        Confirming --> Ready: 等待用户确认
        
        Downloading --> Processing: 下载完成
        Downloading --> Cancelled: 用户取消
        Downloading --> Failed: 下载失败
        
        Processing --> Completed: 处理完成
        Processing --> Failed: 处理失败
        
        Skipped --> Ready: 跳过下载
        Completed --> Ready: 返回就绪
        Cancelled --> Ready: 返回就绪
        Failed --> Ready: 返回就绪
    }
    
    state "🔐 登录状态机" as LoginState {
        [*] --> NotLoggedIn
        
        NotLoggedIn --> WaitingForScan: 触发登录
        
        WaitingForScan --> ScannedWaitingConfirm: 用户扫码
        WaitingForScan --> LoginFailed: 超时/取消
        
        ScannedWaitingConfirm --> LoggedIn: 手机确认
        ScannedWaitingConfirm --> LoginFailed: 取消/超时
        
        LoggedIn --> LoginExpired: Cookie过期
        LoggedIn --> NotLoggedIn: 用户登出
        
        LoginFailed --> NotLoggedIn: 重置状态
        LoginExpired --> NotLoggedIn: 重置状态
    }
    
    state "📋 任务状态机" as TaskState {
        [*] --> Idle
        
        Idle --> InProgress: 开始下载
        
        InProgress --> Duplicate: 检测到重复
        InProgress --> Existing: 检测到已存在
        InProgress --> NewTask: 新任务
        
        Duplicate --> Idle: 跳过
        Existing --> Idle: 确认/跳过
        NewTask --> Executing: 执行下载
        
        Executing --> Success: 下载成功
        Executing --> Failed2: 下载失败
        Executing --> Cancelled2: 用户取消
        
        Success --> Idle: 记录索引
        Failed2 --> Idle: 清理状态
        Cancelled2 --> Idle: 清理状态
    }

    %% 说明
    note right of DownloadState
        下载流程状态流转:
        - Ready: 就绪状态
        - Parsing: 解析视频信息
        - Checking: 检查文件存在
        - Confirming: 等待用户确认
        - Downloading: 下载中
        - Processing: 处理中(合并等)
        - Completed: 完成
        - Cancelled: 已取消
        - Failed: 失败
        - Skipped: 跳过
    end note

    note right of LoginState
        登录状态流转:
        - NotLoggedIn: 未登录
        - WaitingForScan: 等待扫码
        - ScannedWaitingConfirm: 已扫码待确认
        - LoggedIn: 已登录
        - LoginFailed: 登录失败
        - LoginExpired: 登录过期
    end note

    note right of TaskState
        任务管理状态:
        - Idle: 空闲
        - InProgress: 进行中
        - Duplicate: 重复任务
        - Existing: 已存在任务
        - NewTask: 新任务
        - Executing: 执行中
        - Success: 成功
        - Failed: 失败
        - Cancelled: 取消
    end note
