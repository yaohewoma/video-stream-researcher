<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:video_stream_researcher.Controls"
        x:Class="video_stream_researcher.UI.PreviewPlayerWindow"
        Width="1000" Height="700"
        Title="预览">
  <Grid RowDefinitions="*,Auto,Auto" Background="#FF0B0B0F">
    <!-- 视频显示区域 -->
    <Border Grid.Row="0" Margin="12" Background="#FF000000" CornerRadius="6">
      <Grid>
        <Image x:Name="VideoImage" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Stretch="Uniform"/>
        <!-- 调试信息 - 移到右上角，避免遮挡 -->
        <Border Background="#66000000" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Padding="8" CornerRadius="4">
          <TextBlock x:Name="DebugText" Foreground="#FFFFFFFF" FontSize="11" TextWrapping="Wrap" Width="280"/>
        </Border>
      </Grid>
    </Border>

    <!-- 控制按钮区域 - 独立一行，不遮挡视频 -->
    <Border Grid.Row="1" Margin="12,0,12,6" Background="#66000000" CornerRadius="6" Padding="10">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
          <Button x:Name="BtnPlay" Content="播放" Width="70"/>
          <Button x:Name="BtnPause" Content="暂停" Width="70"/>
          <Button x:Name="BtnRestart" Content="重新开始" Width="90"/>
          <Button x:Name="BtnConfirmRange" Content="确认区间并导出" Width="140"/>
          <CheckBox x:Name="ChkDeleteSources" Content="导出后删除源文件" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Column="2" x:Name="TimeText" Foreground="#FFFFFFFF" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- 进度条区域 - 单独一行 -->
    <Border Grid.Row="2" Margin="12,0,12,12" Background="#66000000" CornerRadius="6" Padding="10">
      <controls:RangeSeekBar x:Name="SeekBar" RangeSelectionEnabled="True"/>
    </Border>
  </Grid>
</Window>
